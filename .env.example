# OpenAI API Key - Lấy từ https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ElevenLabs API Key - Lấy từ https://elevenlabs.io/app/api-keys
# Hoặc dùng OpenAI TTS, có thể bỏ trống
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# GitHub Personal Access Token - Lấy từ https://github.com/settings/tokens
# Cần quyền: repo (Full control of private repositories)
GITHUB_TOKEN=ghp-your-github-pat-here

# Tùy chọn: Override defaults
# TTS_PROVIDER=elevenlabs  # hoặc 'openai' hoặc 'gtts'
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Bella (female voice)
# OPENAI_VOICE=alloy  # alloy, echo, fable, onyx, nova, shimmer
# GITHUB_REPO=username/repo-name